/*
 * OPTIONAL — only needed if this board supports the OTA build (scripts/build_ota.*).
 * MCUBOOT image: link MCUboot into boot_partition. Partition sizes live in
 * partitions.dtsi (shared with ota.overlay).
 */

#include "partitions.dtsi"

/ {
	chosen {
		zephyr,code-partition = &boot_partition;
	};
};
