/*
 * OPTIONAL — only needed if this board supports the OTA build (scripts/build_ota.*).
 * APPLICATION image: link the app into slot0. The partition sizes live in
 * partitions.dtsi (shared with mcuboot.overlay). Delete these three files if the
 * board has no OTA support.
 */

#include "partitions.dtsi"

/ {
	chosen {
		zephyr,code-partition = &slot0_partition;
	};
};
