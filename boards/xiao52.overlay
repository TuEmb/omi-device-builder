/*
 * Seeed XIAO nRF52840 Sense overlay.
 *
 * The board DTS already defines the mic (&pdm0 + MSM261 power regulator on
 * P1.10), the RGB gpio-LEDs (led0/led1/led2), and the ADC. We only:
 *   1. expose the mic as the `dmic-dev` alias and enable it,
 *   2. keep the mic power regulator on at boot,
 *   3. add a battery-sense ADC channel (AIN7 = P0.31, divider read-enable P0.14).
 */

#include <zephyr/dt-bindings/adc/adc.h>
#include <zephyr/dt-bindings/adc/nrf-saadc.h>

/ {
	aliases {
		dmic-dev = &pdm0;
	};

	/* Power the on-board MSM261 PDM mic at boot (regulator on P1.10). */
	msm261d3526hicpm-c-en {
		regulator-boot-on;
	};

	zephyr,user {
		io-channels = <&adc 7>;
		batt-enable-gpios = <&gpio0 14 GPIO_ACTIVE_LOW>;
	};
};

&pdm0 {
	status = "okay";
};

&adc {
	#address-cells = <1>;
	#size-cells = <0>;

	channel@7 {
		reg = <7>;
		zephyr,gain = "ADC_GAIN_1_6";
		zephyr,reference = "ADC_REF_INTERNAL";
		zephyr,acquisition-time = <ADC_ACQ_TIME(ADC_ACQ_TIME_MICROSECONDS, 10)>;
		zephyr,input-positive = <NRF_SAADC_AIN7>; /* P0.31 */
		zephyr,resolution = <12>;
	};
};
