source "Kconfig.zephyr"

menu "Omi Device Builder"

comment "Components — a board's hardware is declared in its devicetree; each"
comment "component below auto-enables when the matching DT node/alias exists."
comment "A contributor adding a board normally only edits the .overlay, not this."

config OMI_MIC
    bool "Microphone capture + codec pipeline"
    default y if $(dt_alias_enabled,dmic-dev)
    help
      Microphone capture (feeds the Opus codec + BLE audio stream). Auto-on when
      the board devicetree provides a `dmic-dev` alias (a PDM mic). Turn OFF for
      boards whose mic has no Zephyr driver yet (analog/ESP32 PDM) so the
      firmware still builds as a BLE-only device.

choice OMI_MIC_BACKEND
    prompt "Microphone backend"
    depends on OMI_MIC
    default OMI_MIC_BACKEND_PDM if $(dt_alias_enabled,dmic-dev)
    default OMI_MIC_BACKEND_ADC
    help
      Which driver implements the mic. PDM uses the Zephyr dmic subsystem;
      Analog samples an ADC channel (for analog MEMS mics like the MG24's).

config OMI_MIC_BACKEND_PDM
    bool "PDM (Zephyr dmic)"
    help
      Digital PDM mic via the Zephyr dmic subsystem. Needs a `dmic-dev` alias.

config OMI_MIC_BACKEND_ADC
    bool "Analog (ADC sampling)"
    help
      Analog MEMS mic sampled over ADC. Skeleton only — not implemented yet.

endchoice

config OMI_CODEC_OPUS
    bool "Opus audio codec"
    default y
    help
      Opus audio codec, wire-compatible with the Omi app. The Opus encoder is
      only compiled when OMI_MIC is also on (see CMakeLists), but the codec
      framing constants (CODEC_ID, packet size) are part of the BLE audio
      protocol and are kept available even on BLE-only boards.

config OMI_LED
    bool "Status LED"
    default y if $(dt_compat_enabled,gpio-leds) || $(dt_compat_enabled,pwm-leds)
    help
      Status LED (connection/advertising indication). Auto-on when the board has
      a `gpio-leds` or `pwm-leds` node.

config OMI_BATTERY
    bool "Battery monitoring"
    default y
    help
      Battery voltage (ADC divider) + BLE Battery Service. Enabled by default;
      set =n on boards without battery sensing. (TODO: auto-detect once battery
      moves to a `voltage-divider` devicetree node.)

config OMI_BUTTON
    bool "User button"
    default y if $(dt_alias_enabled,sw0)
    help
      User button (long-press power off). Auto-on when the board devicetree
      provides an `sw0` alias (see overlays/<board>.overlay).

config OMI_STORAGE
    bool "Mass storage (SD card / external NAND flash)"
    default y if $(dt_nodelabel_enabled,sdmmc_disk) || $(dt_nodelabel_enabled,omi_storage)
    help
      Mount a mass-storage backend as a filesystem at /omi. Auto-on when the
      board devicetree provides an SD disk (nodelabel `sdmmc_disk`) or an
      external-flash littlefs partition (nodelabel `omi_storage`).
      (Nodelabels are used instead of compatibles because Kconfig can't pass a
      comma-containing compatible like `zephyr,sdmmc-disk`.)

choice OMI_STORAGE_BACKEND
    prompt "Storage backend"
    depends on OMI_STORAGE
    default OMI_STORAGE_BACKEND_SD if $(dt_nodelabel_enabled,sdmmc_disk)
    default OMI_STORAGE_BACKEND_NAND

config OMI_STORAGE_BACKEND_SD
    bool "SD card (FATFS)"
    select DISK_ACCESS
    select DISK_DRIVER_SDMMC
    select FILE_SYSTEM
    select FAT_FILESYSTEM_ELM
    help
      FATFS on an SD card via disk_access. Needs a `zephyr,sdmmc-disk` node.

config OMI_STORAGE_BACKEND_NAND
    bool "External flash (littlefs)"
    select FLASH
    select FLASH_MAP
    select FILE_SYSTEM
    select FILE_SYSTEM_LITTLEFS
    help
      littlefs on an external flash chip. Needs a flash node (e.g. `spi-nand`)
      with a fixed-partition labelled `omi_storage`.

endchoice

config OMI_STORAGE_SD_DISK_NAME
    string "SD disk-name (must match the devicetree node's disk-name)"
    depends on OMI_STORAGE_BACKEND_SD
    default "SD"

comment "Minimum recommended for a functional device: OMI_MIC + OMI_LED."
comment "BLE-only placeholder boards (no mic/LED driver yet) may disable both."

endmenu
